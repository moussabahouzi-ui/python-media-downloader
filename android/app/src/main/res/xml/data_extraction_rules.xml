<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="device.xml" />
        <!-- Encrypted prefs use Keystore-bound keys that don't survive restore. -->
        <exclude domain="sharedpref" path="mediahub_secure.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="device.xml" />
        <exclude domain="sharedpref" path="mediahub_secure.xml" />
    </device-transfer>
</data-extraction-rules>
